---
import Layout from '@/layouts/Layout.astro';
import Section from '@/components/Section.astro';
import FlexibleGrid from '@/components/FlexibleGrid.astro';
import scienceThemes from '../../data/science-themes.json';
---
<Layout title="Science Themes" description="Cross-cutting science themes connecting glider observations to scientific purpose.">
  <div class="bg-ocean-primary text-white">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <p class="section-subheading text-ocean-secondary">Organization</p>
      <h1 class="text-4xl md:text-5xl font-semibold mb-4 leading-tight">Science Themes</h1>
      <p class="text-white/70 text-lg max-w-xl leading-relaxed">
        Cross-disciplinary focus areas that cut across all three missions, connecting observations to scientific purpose and societal applications.
      </p>
    </div>
  </div>
  <Section>
    <p class="text-ocean-primary/60 mb-12 leading-relaxed">
      While missions organise observations around operational environments, Science Themes represent the scientific and societal questions
      that drive them. Each theme can be taken on by a Task Team where community champions exist to lead focused activities.
    </p>
    <FlexibleGrid cols={3} gap="md">
      {scienceThemes.map(theme => (
        <div class="bg-white rounded-xl shadow-md border border-ocean-light/30 p-6 flex items-center gap-4 hover:shadow-lg transition-shadow duration-200">
          <div class="w-9 h-9 rounded-lg bg-ocean-secondary/10 flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E8795A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={theme.icon}/>
            </svg>
          </div>
          <h3 class="font-semibold text-ocean-primary leading-snug">{theme.name}</h3>
        </div>
      ))}
    </FlexibleGrid>
  </Section>
</Layout>
