---
import Layout from '@/layouts/Layout.astro';
import Section from '@/components/Section.astro';

const b = import.meta.env.BASE_URL;
const base = b.endsWith('/') ? b : b + '/';
---
<Layout title="Organization" description="How OceanGliders is organized — missions, science themes, and task teams.">
  <div class="bg-ocean-primary text-white">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <p class="section-subheading text-ocean-secondary">How We Are Organized</p>
      <h1 class="text-4xl md:text-5xl font-semibold mb-4 leading-tight">Organization</h1>
      <p class="text-white/70 text-lg max-w-xl leading-relaxed">
        OceanGliders is structured around three permanent missions, cross-cutting science themes, and task teams that address specific scientific and technical topics.
      </p>
    </div>
  </div>
  <Section>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <a href={`${base}organization/missions/`} class="bg-white rounded-xl shadow-md border border-ocean-light/30 p-8 hover:shadow-lg transition-shadow duration-200 group">
        <h2 class="text-xl font-semibold text-ocean-primary mb-2 group-hover:text-ocean-secondary transition-colors">Missions</h2>
        <p class="text-ocean-primary/60 text-sm leading-relaxed">BOON, FLOOD, and Polar — three permanent missions organised around distinct operational environments.</p>
      </a>
      <a href={`${base}organization/themes/`} class="bg-white rounded-xl shadow-md border border-ocean-light/30 p-8 hover:shadow-lg transition-shadow duration-200 group">
        <h2 class="text-xl font-semibold text-ocean-primary mb-2 group-hover:text-ocean-secondary transition-colors">Science Themes</h2>
        <p class="text-ocean-primary/60 text-sm leading-relaxed">Cross-cutting themes connecting glider observations to scientific purpose and societal applications.</p>
      </a>
      <a href={`${base}organization/task-teams/`} class="bg-white rounded-xl shadow-md border border-ocean-light/30 p-8 hover:shadow-lg transition-shadow duration-200 group">
        <h2 class="text-xl font-semibold text-ocean-primary mb-2 group-hover:text-ocean-secondary transition-colors">Task Teams</h2>
        <p class="text-ocean-primary/60 text-sm leading-relaxed">Task Teams address specific scientific and technical topics, reporting to the OGST.</p>
      </a>
    </div>
  </Section>
</Layout>
