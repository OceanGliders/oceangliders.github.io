---
import Layout from '@/layouts/Layout.astro';
import Section from '@/components/Section.astro';
import dataManagement from '../../data/data-management.json';
---
<Layout title="Data" description="OceanGliders data management, standards, and network monitoring.">
  <div class="bg-ocean-primary text-white">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <p class="section-subheading text-ocean-secondary">Open Data</p>
      <h1 class="text-4xl md:text-5xl font-semibold mb-4 leading-tight">Data</h1>
      <p class="text-white/70 text-lg max-w-xl leading-relaxed">
        OceanGliders promotes open, accessible, and interoperable glider data aligned with FAIR principles.
      </p>
    </div>
  </div>

  <Section>
    <h2 class="section-heading mb-6">Data Management</h2>
    <p class="text-ocean-primary/60 mb-12 leading-relaxed">
      Data standards, formats, quality control procedures, and best practices are developed through community consensus,
      coordinated by the OceanGliders Data Management Team (OGDMT) and maintained at the OceanGliders GitHub.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {dataManagement.map(item => (
        <div class="bg-white rounded-xl shadow-md border border-ocean-light/30 p-6 hover:shadow-lg transition-shadow duration-200">
          <h3 class="text-ocean-primary font-semibold mb-2">{item.title}</h3>
          <p class="text-ocean-primary/60 text-sm leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
    <div class="mt-8">
      <a href="https://github.com/OceanGlidersCommunity/OG-format-user-manual" target="_blank" rel="noopener"
        class="inline-flex items-center gap-2 text-ocean-secondary font-medium hover:underline text-sm">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
        OG1.0 Format User Manual on GitHub
      </a>
    </div>
  </Section>

  <Section dark>
    <h2 class="text-2xl md:text-3xl font-semibold text-white mb-6">OceanOPS</h2>
    <p class="text-white/70 mb-8 leading-relaxed">
      OceanOPS is the operational centre for GOOS observing networks. It maintains the global registry of glider
      deployments, monitors network status in real time, and ensures glider data are accessible alongside
      observations from complementary GOOS networks.
    </p>
    <a href="https://www.ocean-ops.org/board?t=oceangliders" target="_blank" rel="noopener"
      class="inline-flex items-center gap-2 text-ocean-secondary font-medium hover:underline text-sm">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
      </svg>
      OceanGliders Dashboard at OceanOPS
    </a>
  </Section>
</Layout>
