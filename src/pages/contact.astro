---
import Layout from '@/layouts/Layout.astro';
import Section from '@/components/Section.astro';
import contactRoles from '../data/contact-roles.json';
---

<Layout
  title="Contact"
  description="Get in touch with the OceanGliders steering team."
>
  <!-- Page Hero -->
  <div class="bg-ocean-primary text-white">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <p class="section-subheading text-ocean-secondary">Get in Touch</p>
      <h1 class="text-4xl md:text-5xl font-semibold mb-4 leading-tight">Contact Us</h1>
      <p class="text-white/70 text-lg max-w-xl leading-relaxed">
        Whether you're looking to join the network, share data, or ask a scientific question — we'd love to hear from you.
      </p>
    </div>
  </div>

  <Section>
    <div class="max-w-2xl mx-auto">

      <!-- Guidance text -->
      <div class="mb-10 space-y-3 text-ocean-primary/70 leading-relaxed">
        <p>
          <span class="font-semibold text-ocean-primary">For questions about glider operations, data management, or technical coordination</span> —
          please contact the <span class="text-ocean-secondary font-medium">Technical Coordinator</span>.
        </p>
        <p>
          <span class="font-semibold text-ocean-primary">For questions about data access, data formats, or interoperability</span> —
          please contact the <span class="text-ocean-secondary font-medium">Data Management Leads</span>.
        </p>
        <p>
          <span class="font-semibold text-ocean-primary">For scientific collaboration, mission involvement, or steering group enquiries</span> —
          please contact the <span class="text-ocean-secondary font-medium">Co-Chairs</span>.
        </p>
        <p>
          <span class="font-semibold text-ocean-primary">For community resources, code, and best practices</span> —
          visit the <span class="text-ocean-secondary font-medium">OceanGliders Community on GitHub</span>.
        </p>
      </div>

      <!-- Contact cards -->
      <div class="space-y-4">
        {contactRoles.map(entry => (
          <div class="bg-white rounded-xl shadow-md border border-ocean-light/30 p-5 flex gap-4 items-start">
            <div class="w-8 h-8 rounded-lg bg-ocean-secondary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              {entry.iconType === 'fill' ? (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#2f9dc0">
                  <Fragment set:html={entry.icon} />
                </svg>
              ) : (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2f9dc0" stroke-width="2">
                  <Fragment set:html={entry.icon} />
                </svg>
              )}
            </div>
            <div>
              <p class="font-medium text-ocean-primary text-sm mb-1">{entry.role}</p>
              {entry.contacts ? (
                <div class="space-y-1">
                  {entry.contacts.map(c => (
                    <div>
                      <span class="text-ocean-primary/60 text-sm">{c.name} — </span>
                      <a href={`mailto:${c.email}`} class="text-ocean-secondary text-sm hover:underline">{c.email}</a>
                    </div>
                  ))}
                </div>
              ) : (
                <a href={entry.link} target="_blank" rel="noopener" class="text-ocean-secondary text-sm hover:underline">
                  {entry.linkText}
                </a>
              )}
            </div>
          </div>
        ))}

        <div class="border-t border-ocean-primary/10 pt-6">
          <p class="text-ocean-primary/50 text-sm leading-relaxed text-center">
            OceanGliders is an international programme. We aim to respond to all enquiries within 5 working days.
          </p>
        </div>
      </div>

    </div>
  </Section>
</Layout>
